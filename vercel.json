{
  "rewrites": [
    {
      "source": "/webhooks/squad",
      "destination": "/api/squad-webhook"
    },
    {
      "source": "/webhooks/resend",
      "destination": "/api/resend-webhook"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
