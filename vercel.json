{
  "crons": [
    {
      "path": "/api/auto-payouts-run",
      "schedule": "0 0 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/webhooks/paystack",
      "destination": "/api/paystack-webhook"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
